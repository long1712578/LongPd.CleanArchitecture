{
  "openapi": "3.0.1",
  "info": {
    "title": "LongPd.CleanArchitecture.Api | v1",
    "version": "1.0.0"
  },
  "paths": {
    "/api/events": {
      "post": {
        "tags": [
          "Events"
        ],
        "summary": "Create a new event (draft state).",
        "operationId": "CreateEvent",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateEventRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateEventResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "422": {
            "description": "Unprocessable Entity",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/events/publish": {
      "post": {
        "tags": [
          "Events"
        ],
        "summary": "Publish an event by adding ticket tiers and making it available.",
        "operationId": "PublishEvent",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PublishEventRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "422": {
            "description": "Unprocessable Entity",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/events/{id}": {
      "get": {
        "tags": [
          "Events"
        ],
        "summary": "Get event details by ID, including ticket tiers.",
        "operationId": "GetEventById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EventDetailResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/tickets/available/{eventId}": {
      "get": {
        "tags": [
          "Tickets"
        ],
        "summary": "Get all available ticket tiers for an event.",
        "operationId": "GetAvailableTickets",
        "parameters": [
          {
            "name": "eventId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AvailableTicketResponse"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/tickets/reserve": {
      "post": {
        "tags": [
          "Tickets"
        ],
        "summary": "Reserve tickets — Flash Sale hot path with optimistic concurrency.",
        "operationId": "ReserveTicket",
        "parameters": [
          {
            "name": "X-Idempotency-Key",
            "in": "header",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReserveTicketRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReserveTicketResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "409": {
            "description": "Conflict",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "422": {
            "description": "Unprocessable Entity",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/tickets/cancel": {
      "post": {
        "tags": [
          "Tickets"
        ],
        "summary": "Cancel a reservation and return tickets to the pool.",
        "operationId": "CancelTicket",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CancelTicketRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "422": {
            "description": "Unprocessable Entity",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AvailableTicketResponse": {
        "required": [
          "id",
          "eventId",
          "tierName",
          "price",
          "currency",
          "availableQuantity",
          "isAvailable"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "eventId": {
            "type": "string",
            "format": "uuid"
          },
          "tierName": {
            "type": "string"
          },
          "price": {
            "type": "number",
            "format": "double"
          },
          "currency": {
            "type": "string"
          },
          "availableQuantity": {
            "type": "integer",
            "format": "int32"
          },
          "isAvailable": {
            "type": "boolean"
          }
        }
      },
      "CancelTicketRequest": {
        "required": [
          "ticketId",
          "count"
        ],
        "type": "object",
        "properties": {
          "ticketId": {
            "type": "string",
            "format": "uuid"
          },
          "count": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "CreateEventRequest": {
        "required": [
          "name",
          "description",
          "startDate",
          "endDate",
          "venue",
          "totalCapacity"
        ],
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "startDate": {
            "type": "string",
            "format": "date-time"
          },
          "endDate": {
            "type": "string",
            "format": "date-time"
          },
          "venue": {
            "type": "string"
          },
          "totalCapacity": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "CreateEventResponse": {
        "required": [
          "id",
          "name",
          "isPublished"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "isPublished": {
            "type": "boolean"
          }
        }
      },
      "EventDetailResponse": {
        "required": [
          "id",
          "name",
          "description",
          "startDate",
          "endDate",
          "venue",
          "totalCapacity",
          "isPublished",
          "createdAt",
          "createdBy",
          "ticketTiers"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "startDate": {
            "type": "string",
            "format": "date-time"
          },
          "endDate": {
            "type": "string",
            "format": "date-time"
          },
          "venue": {
            "type": "string"
          },
          "totalCapacity": {
            "type": "integer",
            "format": "int32"
          },
          "isPublished": {
            "type": "boolean"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "createdBy": {
            "type": "string",
            "nullable": true
          },
          "ticketTiers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TicketTierSummary"
            }
          }
        }
      },
      "ProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "nullable": true
          },
          "title": {
            "type": "string",
            "nullable": true
          },
          "status": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "detail": {
            "type": "string",
            "nullable": true
          },
          "instance": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "PublishEventRequest": {
        "required": [
          "eventId",
          "ticketTiers"
        ],
        "type": "object",
        "properties": {
          "eventId": {
            "type": "string",
            "format": "uuid"
          },
          "ticketTiers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TicketTierRequest"
            }
          }
        }
      },
      "ReserveTicketRequest": {
        "required": [
          "ticketId",
          "count"
        ],
        "type": "object",
        "properties": {
          "ticketId": {
            "type": "string",
            "format": "uuid"
          },
          "count": {
            "type": "integer",
            "format": "int32"
          },
          "requestId": {
            "type": "string",
            "format": "uuid",
            "default": null,
            "nullable": true
          }
        }
      },
      "ReserveTicketResponse": {
        "required": [
          "ticketId",
          "eventId",
          "reservedCount",
          "remainingQuantity",
          "totalPrice",
          "currency"
        ],
        "type": "object",
        "properties": {
          "ticketId": {
            "type": "string",
            "format": "uuid"
          },
          "eventId": {
            "type": "string",
            "format": "uuid"
          },
          "reservedCount": {
            "type": "integer",
            "format": "int32"
          },
          "remainingQuantity": {
            "type": "integer",
            "format": "int32"
          },
          "totalPrice": {
            "type": "number",
            "format": "double"
          },
          "currency": {
            "type": "string"
          }
        }
      },
      "TicketTierRequest": {
        "required": [
          "tierName",
          "priceAmount",
          "priceCurrency",
          "quantity"
        ],
        "type": "object",
        "properties": {
          "tierName": {
            "type": "string"
          },
          "priceAmount": {
            "type": "number",
            "format": "double"
          },
          "priceCurrency": {
            "type": "string"
          },
          "quantity": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "TicketTierSummary": {
        "required": [
          "id",
          "tierName",
          "price",
          "currency",
          "totalQuantity",
          "availableQuantity",
          "status"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "tierName": {
            "type": "string"
          },
          "price": {
            "type": "number",
            "format": "double"
          },
          "currency": {
            "type": "string"
          },
          "totalQuantity": {
            "type": "integer",
            "format": "int32"
          },
          "availableQuantity": {
            "type": "integer",
            "format": "int32"
          },
          "status": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Events"
    },
    {
      "name": "Tickets"
    }
  ]
}